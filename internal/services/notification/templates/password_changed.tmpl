{{ define "content" }}
<h2>Password Changed</h2>
<p>Hi {{ .UserName }},</p>
<p>Your password was successfully changed on <strong>{{ .ChangedAt }}</strong>.</p>

<div class="alert-box alert-warning">
  <strong>Wasn't you?</strong> If you did not make this change, please secure your account immediately by resetting your password and reviewing your active sessions.
</div>

{{ if .AppURL }}
<p style="text-align: center; margin: 24px 0;">
  <a href="{{ .AppURL }}/profile" class="btn">Review Account</a>
</p>
{{ end }}
{{ end }}
