{{ define "content" }}
<h2>Welcome to {{ .AppName }}!</h2>
<p>Hi {{ .UserName }},</p>
<p>Your account has been created successfully. You can now start sending emails, managing templates, and configuring your workspace.</p>

{{ if .AppURL }}
<p style="text-align: center; margin: 32px 0;">
  <a href="{{ .AppURL }}" class="btn">Go to Dashboard</a>
</p>
{{ end }}

<p class="muted">If you didn't create this account, please ignore this email.</p>
{{ end }}
